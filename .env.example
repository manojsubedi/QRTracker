# Where /go redirects to (your bank vs GMEBIZ comparison page)
DESTINATION_URL=https://your-service.example.com

# Password protecting /stats dashboard. Pick something hard to guess.
STATS_TOKEN=change-me-to-a-long-random-string

# Upstash Redis credentials — auto-populated when you add the
# "Upstash Redis" integration from Vercel Marketplace.
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
